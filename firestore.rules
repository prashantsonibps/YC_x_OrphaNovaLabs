rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles: users can read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Per-user data collections (projects, experiments, etc.)
    match /users/{userId}/{collection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Global collections (notifications, waitlist, etc.)
    // Any authenticated user can read; only admins can write
    match /notifications/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.email in ['psoni@mail.yu.edu', 'prashantsonibps@gmail.com'];
    }

    match /waitlist_entries/{docId} {
      allow read: if request.auth != null &&
        request.auth.token.email in ['psoni@mail.yu.edu', 'prashantsonibps@gmail.com'];
      allow create: if request.auth != null;
    }

    match /collaboration_posts/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /connection_requests/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /integration_suggestions/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
